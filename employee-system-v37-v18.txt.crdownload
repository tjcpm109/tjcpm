// ── Render / Filtering ──────────────────────────────────────────
function switchRecordSubTab(sub) {
  currentRecordSubTab = sub;
  ['month', 'year', 'detail'].forEach(s => {
    const elTab = document.getElementById('subtab-' + s);
    const elCont = document.getElementById('record-' + s + '-content');
    if (elTab) elTab.classList.toggle('active', s === sub);
    if (elCont) elCont.style.display = s === sub ? 'block' : 'none';
  });
  renderAllList();
}

function filterRecords(type, chip) {
currentFilter = type;
document.querySelectorAll('#record-detail-content .filter-chip').forEach(c => c.classList.remove('active'));
chip.classList.add('active');
renderAllList();
}

function renderAllList() {
  if (!currentUser) return;
  
  // 計算本月考勤與年度累計數據
  calcAttendance();
  
  if (currentRecordSubTab === 'detail') {
    if (currentFilter === '打卡') {
      // 1) 渲染日曆式對帳表
      renderCalendarTable();
    } else {
      // 2) 篩選出目前同仁特定類型的請假/加班/補打卡歷史紀錄並以卡片格式渲染！
      const el = document.getElementById('allRecordsList');
      let mine = records.filter(r => r.empId === currentUser?.empId);
      mine = mine.filter(r => r.type === currentFilter);
      
      el.innerHTML = mine.length 
        ? mine.map(r => recordHTML(r)).join('') 
        : `<div class="empty-state"><div class="empty-icon">📋</div><div class="empty-text">尚無${currentFilter}紀錄</div></div>`;
    }
  }
}

// ── 核心升級：三欄日曆式對帳表格（請假核可豁免，點選自動補卡） ──
function renderCalendarTable() {
  const el = document.getElementById('allRecordsList');
  const now = new Date();
  const year = now.getFullYear();
  const month = now.getMonth() + 1;
  const daysInMonth = new Date(year, month, 0).getDate();
  
  // 1) 篩選出目前同仁本月份的打卡紀錄 (上班 / 下班)
  const minePunch = records.filter(r => {
    if (r.empId !== currentUser?.empId) return false;
    if (r.type !== '上班' && r.type !== '下班') return false;
    const d = new Date(r.date || r.timestamp);
    return d.getFullYear() === year && (d.getMonth() + 1) === month;
  });

  // 2) 篩選出本月份審核通過的請假紀錄 (狀態 === '同意')
  const mineLeave = records.filter(r => {
    if (r.empId !== currentUser?.empId) return false;
    if (r.type !== '請假' || r.status !== '同意') return false;
    const d = new Date(r.date || r.timestamp);
    return d.getFullYear() === year && (d.getMonth() + 1) === month;
  });

  // 3) 按日期重組打卡數據
  const punchMap = {};
  minePunch.forEach(r => {
    const d = new Date(r.date || r.timestamp);
    const dayKey = d.getDate();
    if (!punchMap[dayKey]) punchMap[dayKey] = { 上班: '—', 下班: '—' };
    if (r.type === '上班') punchMap[dayKey].上班 = r.time || '—';
    if (r.type === '下班') punchMap[dayKey].下班 = r.time || '—';
  });

  // 4) 按日期標示已核准的假單
  const leaveMap = {};
  mineLeave.forEach(r => {
    const dStart = new Date(r.date);
    const dEnd = new Date(r.endDate || r.date);
    const sDay = dStart.getDate();
    const eDay = dEnd.getDate();
    const typeLabel = r.subType === '加班補休' ? '補休' : (r.subType || '請假');
    for (let day = sDay; day <= eDay; day++) {
      leaveMap[day] = `🌴 已${typeLabel}`;
    }
  });

  // 5) 渲染 HTML 結構
  let html = `
    <div class="calendar-table-container">
      <table class="calendar-table">
        <thead>
          <tr>
            <th>📅 日期</th>
            <th>🟢 上班簽到</th>
            <th>🏁 下班簽退</th>
          </tr>
        </thead>
        <tbody>
  `;

  for (let day = 1; day <= daysInMonth; day++) {
    const dateObj = new Date(year, month - 1, day);
    const weekdayStr = ['日', '一', '二', '三', '四', '五', '六'][dateObj.getDay()];
    const isWeekend = dateObj.getDay() === 0 || dateObj.getDay() === 6;
    const isToday = day === now.getDate();
    const isFuture = day > now.getDate();
    
    const formattedDate = `${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')} (${weekdayStr})`;
    const dateQueryStr = `${year}-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    
    let punch = punchMap[day] || { 上班: '—', 下班: '—' };
    let leaveLabel = leaveMap[day];

    let checkinHTML = punch.上班;
    let checkoutHTML = punch.下班;

    // 智慧防呆警示判定
    if (isFuture) {
      // 未來日期：無打卡紀錄一律顯示簡潔的 "-"，不產生漏打卡警告
      if (punch.上班 === '—') checkinHTML = '<span style="color:var(--text-muted);font-size:14px;">-</span>';
      if (punch.下班 === '—') checkoutHTML = '<span style="color:var(--text-muted);font-size:14px;">-</span>';
    } else if (isWeekend) {
      // 2) 週末日無打卡：自動標示「休息日」，豁免紅字
      if (punch.上班 === '—') checkinHTML = '<span style="color:var(--text-muted);font-size:13px;">休息日</span>';
      if (punch.下班 === '—') checkoutHTML = '<span style="color:var(--text-muted);font-size:13px;">休息日</span>';
    } else {
      // 3) 一般上班日：使用精準時間段判斷！
      const dayLeaves = mineLeave.filter(r => {
        const startD = new Date(r.date);
        const endD = new Date(r.endDate || r.date);
        return dateObj >= startD && dateObj <= endD;
      }).map(r => {
        const startD = new Date(r.date);
        const endD = new Date(r.endDate || r.date);
        
        let leaveStartMin = 540;
        let leaveEndMin = 1080;
        
        const isStart = dateObj.getFullYear() === startD.getFullYear() && dateObj.getMonth() === startD.getMonth() && dateObj.getDate() === startD.getDate();
        const isEnd = dateObj.getFullYear() === endD.getFullYear() && dateObj.getMonth() === endD.getMonth() && dateObj.getDate() === endD.getDate();
        
        if (isStart && isEnd) {
          leaveStartMin = timeToMin(r.startTime || '09:00');
          leaveEndMin = timeToMin(r.endTime || '18:00');
        } else if (isStart) {
          leaveStartMin = timeToMin(r.startTime || '09:00');
          leaveEndMin = 1080;
        } else if (isEnd) {
          leaveStartMin = 540;
          leaveEndMin = timeToMin(r.endTime || '18:00');
        } else {
          leaveStartMin = 540;
          leaveEndMin = 1080;
        }
        return { start: leaveStartMin, end: leaveEndMin };
      });

      const isTimeExempted = (min, leaves) => {
        if (min >= 720 && min < 780) return true; // lunch is exempt
        return leaves.some(l => min >= l.start && min < l.end);
      };

      const isRangeExempted = (s, e, leaves) => {
        for (let m = s; m < e; m++) {
          if (!isTimeExempted(m, leaves)) return false;
        }
        return true;
      };

      const isMorningExempted = isRangeExempted(540, 720, dayLeaves);
      const isAfternoonExempted = isRangeExempted(780, 1080, dayLeaves);

      if (punch.上班 === '—') {
        if (isMorningExempted) {
          checkinHTML = `<span style="color:var(--text-muted);font-size:13px;">${leaveLabel || '🌴 已請假'}</span>`;
        } else if (!isToday) {
          checkinHTML = `<span style="color:#ef4444;font-weight:bold;font-size:13px;" onclick="autoFillSupp('${dateQueryStr}','上班',event)">⚠️ 漏打卡</span>`;
        } else {
          checkinHTML = '<span style="color:var(--text-muted);font-size:14px;">—</span>';
        }
      }
      
      if (punch.下班 === '—') {
        if (isAfternoonExempted) {
          checkoutHTML = `<span style="color:var(--text-muted);font-size:13px;">${leaveLabel || '🌴 已請假'}</span>`;
        } else if (!isToday) {
          checkoutHTML = `<span style="color:#ef4444;font-weight:bold;font-size:13px;" onclick="autoFillSupp('${dateQueryStr}','下班',event)">⚠️ 漏打卡</span>`;
        } else {
          checkoutHTML = '<span style="color:var(--text-muted);font-size:14px;">—</span>';
        }
      }
    }

    // 當日高亮底色
    const rowStyle = isToday ? 'style="background:var(--card-bg-soft);font-weight:bold;"' : '';
    const clickAttr = (punch.上班 === '—' || punch.下班 === '—') && !isWeekend && !leaveLabel && !isToday && !isFuture
      ? `class="calendar-row-missed" title="點擊漏打卡一鍵補單"`
      : '';

    html += `
      <tr ${rowStyle} ${clickAttr}>
        <td style="color:${isWeekend?'var(--accent-orange)':'var(--text-primary)'}">${formattedDate}</td>
        <td>${checkinHTML}</td>
        <td>${checkoutHTML}</td>
      </tr>
    `;
  }

  html += `
        </tbody>
      </table>
    </div>
  `;
  el.innerHTML = html;
}

// 🎯 UX 爆棚：漏卡自動跳轉並填入日期類型
window.autoFillSupp = function(dateStr, type, event) {
  event.stopPropagation();
  switchTab('supp');
  document.getElementById('suppType').value = type;
  document.getElementById('suppDate').value = dateStr;
  document.getElementById('suppReason').placeholder = `請說明 ${dateStr} 漏打${type}卡原因`;
  showToast(`🔄 已為您自動填入 ${dateStr} ${type} 漏卡資訊！`);
}

function formatDateTimeRange(r) {
  const toSlashDate = (str) => {
    if (!str) return '';
    const clean = str.replace(/-/g, '/');
    const parts = clean.split('/');
    if (parts.length === 3) {
      const y = parts[0];
      const m = parseInt(parts[1], 10);
      const d = parseInt(parts[2], 10);
      return `${y}/${m}/${d}`;
    }
    return clean;
  };
  const startD = toSlashDate(r.date);
  const endD = toSlashDate(r.endDate || r.date);
  const startT = r.startTime || '';
  const endT = r.endTime || '';
  
  let hoursVal = '';
  if (r.hours) {
    const h = parseFloat(r.hours);
    hoursVal = isNaN(h) ? r.hours : String(h).replace(/\.0$/, '');
  }
  const hoursText = hoursVal ? ` 計 ${hoursVal} 小時` : '';

  if (r.type === '請假' || r.type === '加班') {
    if (startD === endD || !r.endDate) {
      return `${startD} ${startT} - ${endT}${hoursText}`;
    } else {
      return `${startD} ${startT} - ${endD} ${endT}${hoursText}`;
    }
  } else if (r.type === '補打卡') {
    return `${startD} ${r.time || ''}`;
  } else {
    // 上班 / 下班 (打卡)
    return `${startD} ${r.time || ''}`;
  }
}

function recordHTML(r, showName = false, showApprove = false) {
let dotClass = 'dot-green', badge = '';
const subTypeLabel = r.subType === '加班補休' ? '補休' : (r.subType || '');

if (r.type === '上班') {
dotClass = 'dot-green';
badge = '<span class="badge badge-green">上班</span>';
} else if (r.type === '下班') {
dotClass = 'dot-red';
badge = '<span class="badge badge-red">下班</span>';
} else if (r.type === '請假') {
dotClass = 'dot-orange';
badge = `<span class="badge badge-orange">${subTypeLabel || '請假'}</span>`;
} else if (r.type === '加班') {
dotClass = 'dot-purple';
badge = '<span class="badge badge-purple">加班</span>';
} else if (r.type === '補打卡') {
dotClass = 'dot-blue';
badge = `<span class="badge badge-blue">補打卡${subTypeLabel ? '·'+subTypeLabel : ''}</span>`;
}
let statusBadge = '';
if (r.status === '待審') statusBadge = '<span class="badge badge-gray" style="margin-left:4px;">待審</span>';
else if (r.status === '同意') statusBadge = '<span class="badge badge-green" style="margin-left:4px;">✓ 同意</span>';
else if (r.status === '拒絕') statusBadge = '<span class="badge badge-red" style="margin-left:4px;">✗ 拒絕</span>';

// 🔒 隱私精簡：隱藏員工端 GPS 精準數值與打卡備註，僅保留 📍位置標記
const showGPS = r.lat ? '📍 位置已驗證' : '';
  const timeInfo = formatDateTimeRange(r);
  const meta = [
    timeInfo,
    showGPS,
    (r.type === '上班' || r.type === '下班') ? '' : r.reason,
    r.approveComment ? `💬 簽核意見：${r.approveComment}` : ''
  ].filter(Boolean).join(' · ');


const who = showName ? `${r.name || r.empId}（${r.empId}）` : '';
const approveRow = showApprove && r.status === '待審' ? `
<div class="approve-row" id="approveBtns-${r.id}">
<button class="approve-btn ok" onclick="toggleApproveComment(${r.id},'同意')">✓ 核准</button>
<button class="approve-btn reject" onclick="toggleApproveComment(${r.id},'拒絕')">✗ 拒絕</button>
</div>
<div class="approve-comment-area" id="approveArea-${r.id}">
<textarea class="approve-comment-input" id="approveComment-${r.id}" placeholder="簽核意見（選填）"></textarea>
<div class="approve-confirm-row">
<button class="approve-btn ok" id="approveConfirmBtn-${r.id}" onclick="confirmApprove(${r.id})">確認送出</button>
<button class="approve-btn reject" onclick="cancelApproveComment(${r.id})">取消</button>
</div>
</div>` : '';

return `<div class="record-item">
<div class="record-row">
<div class="record-dot ${dotClass}"></div>
<div class="record-info">
<div class="record-type">${badge}${statusBadge}${who ? ' ' + who : ''}</div>
<div class="record-meta">${meta}</div>
</div>
<div class="record-time">${r.time || ''}</div>
</div>
${approveRow}
</div>`;
}

// ── Admin ───────────────────────────────────────────────────────
async function loadAdminData() {
  if (!currentUser || currentUser.role !== 'admin') return;
  document.getElementById('pendingLoading').textContent = '載入中…';
  const pending = records.filter(r => r.status === '待審' && (r.type === '請假' || r.type === '加班' || r.type === '補打卡'));
  document.getElementById('statLeave').innerHTML = records.filter(r => r.type === '請假' && r.status === '待審').length + '<span>筆</span>';
  document.getElementById('statOT').innerHTML = records.filter(r => (r.type === '加班' || r.type === '補打卡') && r.status === '待審').length + '<span>筆</span>';
  document.getElementById('pendingList').innerHTML = pending.length ? pending.map(r => recordHTML(r, true, true)).join('') : '<div class="empty-state"><div class="empty-icon">✅</div><div class="empty-text">沒有待審項目</div></div>';
  
  try {
    const data = await callGAS({ action: 'getAll' });
    document.getElementById('pendingLoading').textContent = '';
    if (data.data && data.data.length > 1) {
      const allRows = data.data.slice(1).reverse();
      const today = new Date();
      today.setHours(0,0,0,0);
      const oneWeekAgo = new Date(today);
      oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);

      function parseSheetDate(val) {
        if (!val) return null;
        const d = new Date(val);
        if (isNaN(d.getTime()) || d.getFullYear() < 2000) return null;
        return d;
      }
      function fmtDate(val) {
        const d = parseSheetDate(val);
        if (!d) return '—';
        return d.toLocaleDateString('zh-TW', { year:'numeric', month:'2-digit', day:'2-digit' });
      }
      function fmtTime(val) {
        if (!val) return '—';
        if (typeof val === 'string' && val.match(/^\d{2}:\d{2}/)) return val.slice(0,5);
        const d = new Date(val);
        if (isNaN(d.getTime())) return String(val).slice(0,5) || '—';
        if (d.getFullYear() < 2000) {
          const h = String(d.getUTCHours()).padStart(2,'0');
          const m = String(d.getUTCMinutes()).padStart(2,'0');
          return `${h}:${m}`;
        }
        return d.toLocaleTimeString('zh-TW', { hour:'2-digit', minute:'2-digit', hour12:false });
      }

      const rows = allRows.filter(r => {
        const d = parseSheetDate(r[0]);
        return d && d >= oneWeekAgo;
      });
      const tStr = today.toLocaleDateString('zh-TW');
      document.getElementById('statCheckin').innerHTML = rows.filter(r => r[3] === '上班' && fmtDate(r[0]) === tStr).length + '<span>人</span>';
      document.getElementById('statCheckout').innerHTML = rows.filter(r => r[3] === '下班' && fmtDate(r[0]) === tStr).length + '<span>人</span>';

      // 📊 當月非院內外勤打卡即時穿透
      const currentMonthPunches = allRows.filter(r => {
        if (r[3] !== '上班' && r[3] !== '下班') return false;
        const d = parseSheetDate(r[4] || r[0]);
        if (!d) return false;
        const now = new Date();
        const isCurrentM = d.getFullYear() === now.getFullYear() && (d.getMonth() + 1) === (now.getMonth() + 1);
        const hasRemark = r[8] && String(r[8]).trim() !== '';
        return isCurrentM && hasRemark;
      });

      const fieldPunchesHtml = currentMonthPunches.length ? currentMonthPunches.map(r => `
        <div class="record-item" style="border-left: 4px solid var(--accent-orange);">
          <div class="record-row">
            <div class="record-dot ${r[3]==='上班'?'dot-green':'dot-red'}"></div>
            <div class="record-info">
              <div class="record-type" style="font-weight: bold; color: var(--text-primary);">
                <span class="badge ${r[3]==='上班'?'badge-green':'badge-red'}">${r[3]}</span>
                ${r[2]||''}（${r[1]}）
              </div>
              <div class="record-meta" style="color: var(--text-secondary); margin-top: 4px;">
                📅 ${fmtDate(r[4] || r[0])} · ⏰ ${fmtTime(r[5])} · 💬 <strong>外勤備註：${String(r[8]).trim()}</strong>
              </div>
            </div>
          </div>
        </div>
      `).join('') : '<div class="empty-state"><div class="empty-icon">📋</div><div class="empty-text">當月尚無異地外勤打卡紀錄</div></div>';
      
      document.getElementById('adminFieldPunches').innerHTML = fieldPunchesHtml;

      // 主管端依然完整保留 GPS 數字與備註
      document.getElementById('adminRecords').innerHTML = rows.length ? rows.map(r => `
        <div class="record-item">
          <div class="record-row">
            <div class="record-dot ${r[3]==='上班'?'dot-green':'dot-red'}"></div>
            <div class="record-info">
              <div class="record-type">
                <span class="badge ${r[3]==='上班'?'badge-green':'badge-red'}">${r[3]}</span>
                ${r[2]||''}（${r[1]}）
              </div>
              <div class="record-meta">${fmtDate(r[0])}${r[6]?' 📍'+r[6]+','+r[7]:''}${r[8]?' · 💬 '+r[8]:''}</div>
            </div>
            <div class="record-time">${fmtTime(r[5])}</div>
          </div>
        </div>`).join('') : '<div class="empty-state"><div class="empty-icon">📋</div><div class="empty-text">近一週無打卡紀錄</div></div>';
    }
  } catch (e) {
    document.getElementById('pendingLoading').textContent = '（離線）';
    const oneWeekAgo = new Date(); oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);
    const recentRecords = records.filter(r => new Date(r.timestamp) >= oneWeekAgo);
    document.getElementById('adminRecords').innerHTML = recentRecords.map(r => recordHTML(r, true)).join('') || '<div class="empty-state"><div class="empty-icon">📋</div><div class="empty-text">近一週無打卡紀錄</div></div>';
    const todayStr = new Date().toLocaleDateString('zh-TW');
    document.getElementById('statCheckin').innerHTML = records.filter(r => r.type === '上班' && r.date === todayStr).length + '<span>人</span>';
    document.getElementById('statCheckout').innerHTML = records.filter(r => r.type === '下班' && r.date === todayStr).length + '<span>人</span>';
  }
}

// 👨‍💼 主管：員工考勤多維度穿透查詢
async function handleAdminQueryChange() {
  const empId = document.getElementById('adminQueryUserSelect').value;
  const resultsDiv = document.getElementById('adminQueryResults');
  if (!empId) {
    resultsDiv.style.display = 'none';
    return;
  }
  
  // 顯示加載
  resultsDiv.style.display = 'block';
  document.getElementById('aq-y-ot').textContent = '計算中…';
  document.getElementById('aq-y-miss').textContent = '計算中…';
  document.getElementById('aq-y-late').textContent = '計算中…';
  document.getElementById('aq-y-early').textContent = '計算中…';
  
  try {
    const res = await callGAS({ action: 'getMyStatus', empId: empId });
    if (res.status === 'ok') {
      // 1. 計算年度累計 (自到職日算起)
      const empInfo = currentUser.employeeList.find(e => e.empId === empId);
      const joinDate = parseLocalDate(empInfo ? empInfo.joinDate : '2025/12/01');
      const today = new Date();
      
      const empRecords = res.updates || [];
      
      // 計算累計指標
      let otHoursAcc = 0;
      let missedCount = 0;
      let suppCount = 0;
      let lateCount = 0;
      let earlyCount = 0;
      
      // 加班與補打卡申請
      const mySupps = empRecords.filter(r => r.type === '補打卡');
      suppCount = mySupps.filter(r => r.status === '同意' || r.status === '待審').length;
      
      const myOts = empRecords.filter(r => r.type === '加班' && r.status === '同意');
      myOts.forEach(r => {
        if (r.hours) otHoursAcc += parseFloat(r.hours);
        else if (r.startTime && r.endTime) {
          const sh = parseInt(r.startTime.split(':')[0], 10);
          const sm = parseInt(r.startTime.split(':')[1] || 0, 10);
          const eh = parseInt(r.endTime.split(':')[0], 10);
          const em = parseInt(r.endTime.split(':')[1] || 0, 10);
          otHoursAcc += Math.max(0, (eh * 60 + em - sh * 60 - sm) / 60);
        }
      });

      // 漏打卡、遲到與早退 (按日期彙整)
      const dailyPunches = {};
      const punches = empRecords.filter(r => r.type === '上班' || r.type === '下班');
      punches.forEach(r => {
        const dt = parseLocalDate(r.date);
        if (dt >= joinDate && dt <= today) {
          if (!dailyPunches[r.date]) dailyPunches[r.date] = { in: null, out: null };
          if (r.type === '上班') dailyPunches[r.date].in = r.time;
          if (r.type === '下班') dailyPunches[r.date].out = r.time;
        }
      });
      
      mySupps.filter(r => r.status === '同意').forEach(s => {
        const dt = parseLocalDate(s.date);
        if (dt >= joinDate && dt <= today) {
          if (!dailyPunches[s.date]) dailyPunches[s.date] = { in: null, out: null };
          if (s.subType === '上班') dailyPunches[s.date].in = s.time;
          if (s.subType === '下班') dailyPunches[s.date].out = s.time;
        }
      });

      // 檢查工作日漏打卡與遲到
      let dIndex = new Date(joinDate);
      
      while (dIndex <= today) {
        const dayOfWeek = dIndex.getDay();
        const dateStr = `${dIndex.getFullYear()}/${String(dIndex.getMonth()+1).padStart(2,'0')}/${String(dIndex.getDate()).padStart(2,'0')}`;
        
        // 排除週末與國定假日
        const isHoliday = res.holidayStrings && res.holidayStrings.includes(dateStr.replace(/\//g, '-'));
        
        if (dayOfWeek !== 0 && dayOfWeek !== 6 && !isHoliday) {
          const punch = dailyPunches[dateStr];
          
          // 1. Gather all approved leaves covering dIndex for this employee
          const dayLeaves = empRecords.filter(r => {
            if (r.type !== '請假' || r.status !== '同意') return false;
            const startD = parseLocalDate(r.date);
            const endD = parseLocalDate(r.endDate || r.date);
            return dIndex >= startD && dIndex <= endD;
          }).map(r => {
            const startD = parseLocalDate(r.date);
            const endD = parseLocalDate(r.endDate || r.date);
            
            let leaveStartMin = 540;
            let leaveEndMin = 1080;
            
            const isStart = dIndex.getFullYear() === startD.getFullYear() && dIndex.getMonth() === startD.getMonth() && dIndex.getDate() === startD.getDate();
            const isEnd = dIndex.getFullYear() === endD.getFullYear() && dIndex.getMonth() === endD.getMonth() && dIndex.getDate() === endD.getDate();
            
            if (isStart && isEnd) {
              leaveStartMin = timeToMin(r.startTime || '09:00');
              leaveEndMin = timeToMin(r.endTime || '18:00');
            } else if (isStart) {
              leaveStartMin = timeToMin(r.startTime || '09:00');
              leaveEndMin = 1080;
            } else if (isEnd) {
              leaveStartMin = 540;
              leaveEndMin = timeToMin(r.endTime || '18:00');
            } else {
              leaveStartMin = 540;
              leaveEndMin = 1080;
            }
            return { start: leaveStartMin, end: leaveEndMin };
          });

          const isTimeExempted = (min, leaves) => {
            if (min >= 720 && min < 780) return true; // lunch is exempt
            return leaves.some(l => min >= l.start && min < l.end);
          };

          const isRangeExempted = (s, e, leaves) => {
            for (let m = s; m < e; m++) {
              if (!isTimeExempted(m, leaves)) return false;
            }
            return true;
          };

          const isFullDayExempted = isRangeExempted(540, 1080, dayLeaves);
          
          if (!isFullDayExempted) {
            if (!punch || (!punch.in && !punch.out)) {
              missedCount += 2;
            } else {
              if (!punch.in) {
                missedCount += 1;
              } else {
                const punchInMin = timeToMin(punch.in);
                if (punchInMin > 540) {
                  if (!isRangeExempted(540, punchInMin, dayLeaves)) {
                    lateCount++;
                  }
                }
              }
              if (!punch.out) {
                missedCount += 1;
              } else {
                const punchOutMin = timeToMin(punch.out);
                if (punchOutMin < 1080) {
                  if (!isRangeExempted(punchOutMin, 1080, dayLeaves)) {
                    earlyCount++;
                  }
                }
              }
            }
          }
        }
        dIndex.setDate(dIndex.getDate() + 1);
      }

      document.getElementById('aq-y-ot').textContent = otHoursAcc.toFixed(1) + ' h';
      document.getElementById('aq-y-miss').textContent = missedCount + ' 次';
      document.getElementById('aq-y-late').textContent = lateCount + ' 次';
      document.getElementById('aq-y-early').textContent = earlyCount + ' 次';

      // 2. 生成每月明細表格 (自到職月至今每月統計)
      const monthlyBody = document.getElementById('adminQueryMonthlyBody');
      monthlyBody.innerHTML = '';
      
      const startYear = joinDate.getFullYear();
      const startMonth = joinDate.getMonth();
      const endYear = today.getFullYear();
      const endMonth = today.getMonth();
      
      let monthsList = [];
      let cy = startYear, cm = startMonth;
      while (cy < endYear || (cy === endYear && cm <= endMonth)) {
        monthsList.push({ year: cy, month: cm });
        cm++;
        if (cm > 11) { cm = 0; cy++; }
      }
      
      // 倒序顯示最近月份
      monthsList.reverse();
      
      let monthlyRowsHtml = '';
      monthsList.forEach(m => {
        const label = `${m.year}-${String(m.month+1).padStart(2,'0')}`;
        const startMDate = new Date(m.year, m.month, 1);
        const endMDate = new Date(m.year, m.month + 1, 0);
        
        const mRecords = empRecords.filter(r => {
          const d = r.date || r.timestamp;
          if (!d) return false;
          const dt = parseLocalDate(d);
          return dt >= startMDate && dt <= endMDate;
        });

        // 統計該月數值
        let mOt = 0;
        let mSupp = 0;
        let mMiss = 0;
        let mLate = 0;
        let mEarly = 0;
        let mLeave = 0;

        mRecords.forEach(r => {
          if (r.type === '加班' && r.status === '同意') {
            if (r.hours) mOt += parseFloat(r.hours);
            else if (r.startTime && r.endTime) {
              const sh = parseInt(r.startTime.split(':')[0], 10);
              const sm = parseInt(r.startTime.split(':')[1] || 0, 10);
              const eh = parseInt(r.endTime.split(':')[0], 10);
              const em = parseInt(r.endTime.split(':')[1] || 0, 10);
              mOt += Math.max(0, (eh * 60 + em - sh * 60 - sm) / 60);
            }
          }
          if (r.type === '補打卡' && (r.status === '同意' || r.status === '待審')) {
            mSupp++;
          }
          if (r.type === '請假' && r.status === '同意') {
            const startD = parseLocalDate(r.date);
            const endD = parseLocalDate(r.endDate || r.date);
            const daysCount = Math.round(Math.abs(endD - startD) / (1000 * 60 * 60 * 24)) + 1;
            if (r.startTime && r.endTime) {
              const sh = parseInt(r.startTime.split(':')[0], 10);
              const sm = parseInt(r.startTime.split(':')[1] || 0, 10);
              const eh = parseInt(r.endTime.split(':')[0], 10);
              const em = parseInt(r.endTime.split(':')[1] || 0, 10);
              let diff = (eh * 60 + em - sh * 60 - sm) / 60;
              if (sh <= 12 && eh >= 13) diff -= 1.0;
              mLeave += Math.max(0, diff) * daysCount;
            } else {
              mLeave += 8 * daysCount;
            }
          }
        });

        // 每月漏打卡、遲到早退
        const mPunches = {};
        mRecords.filter(r => r.type === '上班' || r.type === '下班').forEach(r => {
          if (!mPunches[r.date]) mPunches[r.date] = { in: null, out: null };
          if (r.type === '上班') mPunches[r.date].in = r.time;
          if (r.type === '下班') mPunches[r.date].out = r.time;
        });
        mRecords.filter(r => r.type === '補打卡' && r.status === '同意').forEach(r => {
          if (!mPunches[r.date]) mPunches[r.date] = { in: null, out: null };
          if (r.subType === '上班') mPunches[r.date].in = r.time;
          if (r.subType === '下班') mPunches[r.date].out = r.time;
        });

        // 跑每月天數比對
        const daysInM = endMDate.getDate();
        for (let d = 1; d <= daysInM; d++) {
          const dateObj = new Date(m.year, m.month, d);
          const dayOfWeek = dateObj.getDay();
          const dateStr = `${m.year}/${String(m.month+1).padStart(2,'0')}/${String(d).padStart(2,'0')}`;
          
          const isHoliday = res.holidayStrings && res.holidayStrings.includes(dateStr.replace(/\//g, '-'));
          
          if (dayOfWeek !== 0 && dayOfWeek !== 6 && !isHoliday && dateObj >= joinDate && dateObj <= today) {
            const punch = mPunches[dateStr];
            
            // 1. Gather all approved leaves covering dateObj for this employee
            const dayLeaves = mRecords.filter(r => {
              if (r.type !== '請假' || r.status !== '同意') return false;
              const startD = parseLocalDate(r.date);
              const endD = parseLocalDate(r.endDate || r.date);
              return dateObj >= startD && dateObj <= endD;
            }).map(r => {
              const startD = parseLocalDate(r.date);
              const endD = parseLocalDate(r.endDate || r.date);
              
              let leaveStartMin = 540;
              let leaveEndMin = 1080;
              
              const isStart = dateObj.getFullYear() === startD.getFullYear() && dateObj.getMonth() === startD.getMonth() && dateObj.getDate() === startD.getDate();
              const isEnd = dateObj.getFullYear() === endD.getFullYear() && dateObj.getMonth() === endD.getMonth() && dateObj.getDate() === endD.getDate();
              
              if (isStart && isEnd) {
                leaveStartMin = timeToMin(r.startTime || '09:00');
                leaveEndMin = timeToMin(r.endTime || '18:00');
              } else if (isStart) {
                leaveStartMin = timeToMin(r.startTime || '09:00');
                leaveEndMin = 1080;
              } else if (isEnd) {
                leaveStartMin = 540;
                leaveEndMin = timeToMin(r.endTime || '18:00');
              } else {
                leaveStartMin = 540;
                leaveEndMin = 1080;
              }
              return { start: leaveStartMin, end: leaveEndMin };
            });

            const isTimeExempted = (min, leaves) => {
              if (min >= 720 && min < 780) return true; // lunch is exempt
              return leaves.some(l => min >= l.start && min < l.end);
            };

            const isRangeExempted = (s, e, leaves) => {
              for (let m = s; m < e; m++) {
                if (!isTimeExempted(m, leaves)) return false;
              }
              return true;
            };

            const isFullDayExempted = isRangeExempted(540, 1080, dayLeaves);

            if (!isFullDayExempted) {
              if (!punch || (!punch.in && !punch.out)) {
                mMiss += 2;
              } else {
                if (!punch.in) {
                  mMiss += 1;
                } else {
                  const punchInMin = timeToMin(punch.in);
                  if (punchInMin > 540) {
                    if (!isRangeExempted(540, punchInMin, dayLeaves)) {
                      mLate++;
                    }
                  }
                }
                if (!punch.out) {
                  mMiss += 1;
                } else {
                  const punchOutMin = timeToMin(punch.out);
                  if (punchOutMin < 1080) {
                    if (!isRangeExempted(punchOutMin, 1080, dayLeaves)) {
                      mEarly++;
                    }
                  }
                }
              }
            }
          }
        }

        monthlyRowsHtml += `
          <tr style="border-bottom:1px solid #cbd5e1;">
            <td style="padding:8px;text-align:center;font-weight:bold;">${label}</td>
            <td style="padding:8px;text-align:center;">${mLate + mEarly} 次</td>
            <td style="padding:8px;text-align:center;">${mOt.toFixed(1)} h</td>
            <td style="padding:8px;text-align:center;color:#dc2626;font-weight:bold;">${mMiss} 次</td>
            <td style="padding:8px;text-align:center;">${mSupp} 次</td>
            <td style="padding:8px;text-align:center;">${mLeave.toFixed(1)} h</td>
          </tr>`;
      });
      monthlyBody.innerHTML = monthlyRowsHtml;
    }
  } catch (err) {
    showToast('⚠️ 載入穿透看盤數據失敗');
  }
}

// ── Helpers ─────────────────────────────────────────────────────
function saveRecords() {
localStorage.setItem('tjcpm_records', JSON.stringify(records));
}

function switchTab(tab) {
if (tab === 'admin' && (!currentUser || currentUser.role !== 'admin')) {
return;
}
document.querySelectorAll('.nav-tab').forEach(t => {
t.classList.toggle('active', t.dataset.tab === tab);
});
document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
document.getElementById('page-' + tab).classList.add('active');
if (tab === 'records') renderAllList();
if (tab === 'admin') loadAdminData();
if (tab === 'profile') renderProfile();
}

function openModal(type) {
document.getElementById('modal-' + type).classList.add('open');
}
function closeModal(type) {
document.getElementById('modal-' + type).classList.remove('open');
}

let toastTimer;
function showToast(msg) {
const el = document.getElementById('toast');
el.textContent = msg;
el.classList.add('show');
clearTimeout(toastTimer);
toastTimer = setTimeout(() => el.classList.remove('show'), 2800);
}
document.querySelectorAll('.modal-overlay').forEach(o => {
o.addEventListener('click', e => {
if (e.target === o) o.classList.remove('open');
});
});

// ── 時間下拉選單：只允許 :00 和 :30 ────────────────────────────
(function initTimeSelects() {
const ids = ['leaveStartTime', 'leaveEndTime', 'otStart', 'otEnd', 'suppTime'];
const options = [];
for (let h = 0; h < 24; h++) {
const hh = String(h).padStart(2, '0');
options.push('<option value="' + hh + ':00">' + hh + ':00</option>');
options.push('<option value="' + hh + ':30">' + hh + ':30</option>');
}
const html = options.join('');
ids.forEach(id => {
const el = document.getElementById(id);
if (el) el.innerHTML = html;
});
['leaveStartTime','otStart'].forEach(id => {
const el = document.getElementById(id);
if (el) el.value = '08:00';
});
['leaveEndTime','otEnd'].forEach(id => {
const el = document.getElementById(id);
if (el) el.value = '17:00';
});
const suppEl = document.getElementById('suppTime');
if (suppEl) suppEl.value = '08:00';
})();

// ── 主管簽核 ──
let pendingApproveDecision = {};
function toggleApproveComment(id, decision) {
document.querySelectorAll('.approve-comment-area.open').forEach(el => {
const rid = el.id.replace('approveArea-','');
if (String(rid) !== String(id)) {
el.classList.remove('open');
const btns = document.getElementById('approveBtns-' + rid);
if (btns) btns.style.display = 'flex';
}
});
const area = document.getElementById('approveArea-' + id);
const btns = document.getElementById('approveBtns-' + id);
if (!area) { approveRecord(id, decision); return; }
pendingApproveDecision[id] = decision;
area.classList.add('open');
if (btns) btns.style.display = 'none';
const confirmBtn = document.getElementById('approveConfirmBtn-' + id);
if (confirmBtn) {
confirmBtn.textContent = decision === '同意' ? '✓ 確認核准' : '✗ 確認拒絕';
confirmBtn.className = 'approve-btn ' + (decision === '同意' ? 'ok' : 'reject');
}
const ta = document.getElementById('approveComment-' + id);
if (ta) setTimeout(() => ta.focus(), 100);
}

function cancelApproveComment(id) {
const area = document.getElementById('approveArea-' + id);
if (area) area.classList.remove('open');
const btns = document.getElementById('approveBtns-' + id);
if (btns) btns.style.display = 'flex';
delete pendingApproveDecision[id];
}

function confirmApprove(id) {
const decision = pendingApproveDecision[id];
if (!decision) return;
const commentEl = document.getElementById('approveComment-' + id);
const comment = commentEl ? commentEl.value.trim() : '';
approveRecord(id, decision, comment);
delete pendingApproveDecision[id];
}

async function approveRecord(id, decision, comment) {
if (!currentUser || currentUser.role !== 'admin') {
showToast('⚠️ 您沒有審核權限');
return;
}
const rec = records.find(r => r.id === id);
if (!rec) return;
rec.status = decision;
if (comment) rec.approveComment = comment;
saveRecords();
const msg = `已${decision}：${rec.name}（${rec.empId}）的${rec.type}申請（${rec.date}）${comment ? '，意見：' + comment : ''}`;
addNotif(decision === '同意' ? 'approve' : 'reject', msg);
sendPush('TJCPM 審批', msg);
try {
const res = await callGAS({
action: 'approve', clientId: rec.clientId || String(rec.id),
empId: rec.empId, type: rec.type, date: rec.date, decision,
approverName: currentUser.name, approverId: currentUser.empId,
comment: comment || ''
});
const synced = res.status === 'ok' && res.found !== false;
showToast(decision === '同意'
? (synced ? '✅ 已核准並同步' : '✅ 已核准（Sheet 未找到對應列）')
: (synced ? '❌ 已拒絕並同步' : '❌ 已拒絕（Sheet 未找到對應列）'));
} catch (e) {
showToast(decision === '同意' ? '✅ 已核准（離線）' : '❌ 已拒絕（離線）');
}
loadAdminData();
}

// ── 個人資料頁 ────────────────────────────────────────────────
function renderProfile() {
if (!currentUser) return;
const name = currentUser.name || '—';
const empId = currentUser.empId || '—';
const initial = name.charAt(0) || '?';
// 已移除重複的大頭貼與姓名欄位更新
document.getElementById('profileNameVal').textContent = name;
document.getElementById('profileEmpIdVal').textContent = empId;
document.getElementById('profileJoinDate').textContent = currentUser.joinDate || '—';
const empTypeEl = document.getElementById('profileEmpType');
if (empTypeEl) {
  empTypeEl.textContent = currentUser.empType || '專任';
}

calcAttendance();
syncProfileAndAccumulatedLeaves();
}

// 實時向後端拉取最新的特休、補休餘額與年度假別累加時數
async function syncProfileAndAccumulatedLeaves() {
  try {
    const data = await callGAS({ action: 'getMyStatus', empId: currentUser.empId });
    if (data.status === 'ok' && data.updates) {
      // 100% 覆蓋本機緩存紀錄，實現跨裝置即時同步
      records = data.updates;
      saveRecords();

      // 精算特休與補休餘額 (優先自後台 quota 獲取，保持與 Excel 絕對對齊)
      let annualLeaveUsed = 0;
      let compLeaveUsed = 0;
      let sickLeaveUsed = 0;
      let personalLeaveUsed = 0;
      let govLeaveUsed = 0;

      records.forEach(r => {
        if (r.type === '請假' && r.status === '同意') {
          const leaveType = r.subType === '加班補休' ? '補休' : (r.subType || '');
          const hours = parseFloat(r.hours) || 0;
          if (leaveType === '特休') annualLeaveUsed += hours;
          else if (leaveType === '補休') compLeaveUsed += hours;
          else if (leaveType === '病假') sickLeaveUsed += hours;
          else if (leaveType === '事假') personalLeaveUsed += hours;
          else if (leaveType === '公假' || leaveType === '婚假' || leaveType === '喪假') govLeaveUsed += hours;
        }
      });

      let annualRemaining = 24;
      let compRemaining = 16;

      if (data.quota) {
        annualRemaining = data.quota.specialLeaveRemaining;
        compRemaining = data.quota.compLeaveRemaining;
        annualLeaveUsed = data.quota.specialLeaveUsed;
        
        // 同步儲存至 currentUser 中，確保全系統共享
        currentUser.quota = data.quota;
        sessionStorage.setItem('tjcpm_user', JSON.stringify(currentUser));
      } else {
        // 舊版或無 quota 回傳時之手動估算
        let annualBase = currentUser.empId === '115' ? 24 : (currentUser.empId === '111' ? 112 : 80);
        let compBase = 16;
        annualRemaining = Math.max(0, annualBase - annualLeaveUsed);
        compRemaining = Math.max(0, compBase - compLeaveUsed);
      }

      document.getElementById('profileAnnualLeave').textContent = `${annualRemaining} 小時`;
      document.getElementById('profileCompensatoryLeave').textContent = `${compRemaining} 小時`;

      // 寫入勞基法說明卡中的「今年已請」累計時數
      document.getElementById('accumAnnual').textContent = `${annualLeaveUsed}h`;
      document.getElementById('accumComp').textContent = `${compLeaveUsed}h`;
      document.getElementById('accumSick').textContent = `${sickLeaveUsed}h`;
      document.getElementById('accumPersonal').textContent = `${personalLeaveUsed}h`;
      document.getElementById('accumGov').textContent = `${govLeaveUsed}h`;
    }
  } catch (e) {
    console.error('拉取雲端考勤餘額與累計失敗:', e);
  }
}


// 💡 日期格式標準化輔助函式 (YYYY/M/D)
function normalizeDate(str) {
  if (!str) return '';
  const clean = str.replace(/-/g, '/');
  const parts = clean.split('/');
  if (parts.length === 3) {
    const y = parseInt(parts[0], 10);
    const m = parseInt(parts[1], 10);
    const d = parseInt(parts[2], 10);
    return `${y}/${m}/${d}`;
  }
  return clean;
}


function timeToMin(timeStr) {
  if (!timeStr) return 540; // Default to 09:00 if empty
  const parts = timeStr.split(':');
  return parseInt(parts[0], 10) * 60 + parseInt(parts[1] || 0, 10);
}

function calcAttendance() {
  if (!currentUser) return;
  const now = new Date();
  const thisYear = now.getFullYear();
  const thisMonth = now.getMonth() + 1;
  const todayDate = now.getDate();
  const daysInMonth = new Date(thisYear, thisMonth, 0).getDate();
  
  // 💡 V37-v16 智慧日期截斷：如果是本月，漏卡統計只計算至「昨天 (前一天)」
  let endDayCheck = daysInMonth;
  if (thisYear === now.getFullYear() && thisMonth === (now.getMonth() + 1)) {
    endDayCheck = todayDate - 1; // 💡 僅統計 1 日至昨天 (todayDate - 1)
  } else if (thisYear > now.getFullYear() || (thisYear === now.getFullYear() && thisMonth > (now.getMonth() + 1))) {
    endDayCheck = 0; // 未來月份，漏卡數直接歸零 0
  }

  const myRecords = records.filter(r => {
    if (r.empId !== currentUser?.empId) return false;
    const d = r.date || r.timestamp;
    if (!d) return false;
    const dt = new Date(d);
    return dt.getFullYear() === thisYear && (dt.getMonth() + 1) === thisMonth;
  });

  // 1. 本月加班時數 (主管同意的)
  let otHours = 0;
  const approvedOts = myRecords.filter(r => r.type === '加班' && r.status === '同意');
  approvedOts.forEach(r => {
    if (r.hours) otHours += parseFloat(r.hours);
    else if (r.startTime && r.endTime) {
      const sh = parseInt(r.startTime.split(':')[0], 10);
      const sm = parseInt(r.startTime.split(':')[1] || 0, 10);
      const eh = parseInt(r.endTime.split(':')[0], 10);
      const em = parseInt(r.endTime.split(':')[1] || 0, 10);
      otHours += Math.max(0, (eh * 60 + em - sh * 60 - sm) / 60);
    }
  });

  // 2. 本月補打卡次數 (主管同意或待審)
  const suppCount = myRecords.filter(r => r.type === '補打卡' && (r.status === '同意' || r.status === '待審')).length;

  // 3. 本月請假總時數 (主管同意的)
  let leaveHours = 0;
  const approvedLeaves = myRecords.filter(r => r.type === '請假' && r.status === '同意');
  approvedLeaves.forEach(r => {
    if (r.hours) {
      leaveHours += parseFloat(r.hours);
    } else {
      const startD = new Date(r.date);
      const endD = new Date(r.endDate || r.date);
      const daysCount = Math.round(Math.abs(endD - startD) / (1000 * 60 * 60 * 24)) + 1;
      if (r.startTime && r.endTime) {
        const sh = parseInt(r.startTime.split(':')[0], 10);
        const sm = parseInt(r.startTime.split(':')[1] || 0, 10);
        const eh = parseInt(r.endTime.split(':')[0], 10);
        const em = parseInt(r.endTime.split(':')[1] || 0, 10);
        let diff = (eh * 60 + em - sh * 60 - sm) / 60;
        if (sh <= 12 && eh >= 13) diff -= 1.0;
        leaveHours += Math.max(0, diff) * daysCount;
      } else {
        leaveHours += 8 * daysCount;
      }
    }
  });

  // 4. 統計本月每日打卡狀態與未打卡 (💡 使用智慧標準化日期對齊，徹底消除補漏打卡統計天數膨脹 Bug)
  const dailyPunches = {};
  myRecords.forEach(r => {
    if (r.type === '上班' || r.type === '下班') {
      const normD = normalizeDate(r.date);
      if (!dailyPunches[normD]) dailyPunches[normD] = { in: null, out: null };
      if (r.type === '上班') {
        if (!dailyPunches[normD].in || r.time < dailyPunches[normD].in) dailyPunches[normD].in = r.time;
      } else if (r.type === '下班') {
        if (!dailyPunches[normD].out || r.time > dailyPunches[normD].out) dailyPunches[normD].out = r.time;
      }
    }
  });

  myRecords.filter(r => r.type === '補打卡' && r.status === '同意').forEach(r => {
    const normD = normalizeDate(r.date);
    if (!dailyPunches[normD]) dailyPunches[normD] = { in: null, out: null };
    if (r.subType === '上班') dailyPunches[normD].in = r.time;
    if (r.subType === '下班') dailyPunches[normD].out = r.time;
  });

  let missedCount = 0;
  let lateCount = 0;
  let earlyCount = 0;

  for (let d = 1; d <= endDayCheck; d++) {
    const dateObj = new Date(thisYear, thisMonth - 1, d);
    const dayOfWeek = dateObj.getDay();
    const dateStr = `${thisYear}/${thisMonth}/${d}`; // 💡 使用無補零之標準 M/D 格式對齊
    
    // We can check if it's weekend
    const isWeekend = (dayOfWeek === 0 || dayOfWeek === 6);
    
    if (!isWeekend) {
      const punch = dailyPunches[dateStr];
      
      // 1. Gather all approved leaves covering dateObj for this employee
      const dayLeaves = myRecords.filter(r => {
        if (r.type !== '請假' || r.status !== '同意') return false;
        const startD = new Date(r.date);
        const endD = new Date(r.endDate || r.date);
        return dateObj >= startD && dateObj <= endD;
      }).map(r => {
        const startD = new Date(r.date);
        const endD = new Date(r.endDate || r.date);
        
        let leaveStartMin = 540;
        let leaveEndMin = 1080;
        
        const isStart = dateObj.getFullYear() === startD.getFullYear() && dateObj.getMonth() === startD.getMonth() && dateObj.getDate() === startD.getDate();
        const isEnd = dateObj.getFullYear() === endD.getFullYear() && dateObj.getMonth() === endD.getMonth() && dateObj.getDate() === endD.getDate();
        
        if (isStart && isEnd) {
          leaveStartMin = timeToMin(r.startTime || '09:00');
          leaveEndMin = timeToMin(r.endTime || '18:00');
        } else if (isStart) {
          leaveStartMin = timeToMin(r.startTime || '09:00');
          leaveEndMin = 1080;
        } else if (isEnd) {
          leaveStartMin = 540;
          leaveEndMin = timeToMin(r.endTime || '18:00');
        } else {
          leaveStartMin = 540;
          leaveEndMin = 1080;
        }
        return { start: leaveStartMin, end: leaveEndMin };
      });

      // 2. Helper functions
      const isTimeExempted = (min, leaves) => {
        if (min >= 720 && min < 780) return true; // lunch is exempt
        return leaves.some(l => min >= l.start && min < l.end);
      };

      const isRangeExempted = (s, e, leaves) => {
        for (let m = s; m < e; m++) {
          if (!isTimeExempted(m, leaves)) return false;
        }
        return true;
      };

      const isFullDayExempted = isRangeExempted(540, 1080, dayLeaves);

      if (!isFullDayExempted) {
        if (!punch || (!punch.in && !punch.out)) {
          missedCount += 2;
        } else {
          if (!punch.in) {
            missedCount += 1;
          } else {
            const punchInMin = timeToMin(punch.in);
            if (punchInMin > 540) {
              if (!isRangeExempted(540, punchInMin, dayLeaves)) {
                lateCount++;
              }
            }
          }
          if (!punch.out) {
            missedCount += 1;
          } else {
            const punchOutMin = timeToMin(punch.out);
            if (punchOutMin < 1080) {
              if (!isRangeExempted(punchOutMin, 1080, dayLeaves)) {
                earlyCount++;
              }
            }
          }
        }
      }
    }
  }

  // Update profile cards
  const checkinDays = new Set(myRecords.filter(r => r.type === '上班').map(r => r.date)).size;
  const leaveCount = myRecords.filter(r => r.type === '請假').length;

  const attTotalEl = document.getElementById('attTotal');
  const attMissedEl = document.getElementById('attMissed');
  const attLateEl = document.getElementById('attLate');
  const attLeaveEl = document.getElementById('attLeave');

  if (attTotalEl) attTotalEl.textContent = checkinDays;
  if (attMissedEl) attMissedEl.textContent = missedCount;
  if (attLateEl) attLateEl.textContent = lateCount;
  if (attLeaveEl) attLeaveEl.textContent = leaveCount;

  // Update month summary elements
  const mOtEl = document.getElementById('m-ot');
  const mMissEl = document.getElementById('m-miss');
  const mSuppEl = document.getElementById('m-supp');
  const mLateEl = document.getElementById('m-late');
  const mEarlyEl = document.getElementById('m-early');
  const mLeaveEl = document.getElementById('m-leave');

  if (mOtEl) mOtEl.textContent = otHours.toFixed(1) + ' h';
  if (mMissEl) mMissEl.textContent = missedCount + ' 次';
  if (mSuppEl) mSuppEl.textContent = suppCount + ' 次';
  if (mLateEl) mLateEl.textContent = lateCount + ' 次';
  if (mEarlyEl) mEarlyEl.textContent = earlyCount + ' 次';
  if (mLeaveEl) mLeaveEl.textContent = leaveHours.toFixed(1) + ' h';

  // Update yearly summary elements
  const yOtEl = document.getElementById('y-ot');
  const yMissEl = document.getElementById('y-miss');
  const yLateEarlyEl = document.getElementById('y-lateearly');

  if (currentUser && currentUser.quota) {
    const q = currentUser.quota;
    if (yOtEl) yOtEl.textContent = (q.specialLeaveHours - q.specialLeaveRemaining).toFixed(1) + ' h';
    if (yMissEl) yMissEl.textContent = missedCount + ' 次';
    if (yLateEarlyEl) yLateEarlyEl.textContent = (lateCount + earlyCount) + ' 次';
  }
}

function togglePwChange() {
const area = document.getElementById('pwChangeArea');
area.classList.toggle('open');
if (area.classList.contains('open')) {
document.getElementById('pwOld').focus();
} else {
['pwOld','pwNew','pwConfirm'].forEach(id => {
document.getElementById(id).value = '';
});
}
}

async function changePassword() {
const oldPw = document.getElementById('pwOld').value;
const newPw = document.getElementById('pwNew').value;
const confirm = document.getElementById('pwConfirm').value;
if (!oldPw || !newPw || !confirm) { showToast('⚠️ 請填寫所有密碼欄位'); return; }
if (newPw !== confirm) { showToast('⚠️ 新密碼與確認密碼不一致'); return; }
if (newPw.length < 4) { showToast('⚠️ 新密碼至少需要 4 個字元'); return; }
try {
const res = await callGAS({
action: 'changePassword',
empId: currentUser.empId,
oldPassword: oldPw,
newPassword: newPw
});
if (res.status === 'ok') {
showToast('✅ 密碼已成功修改');
togglePwChange();
} else {
showToast('⚠️ ' + (res.message || '舊密碼不正確'));
}
} catch (e) {
showToast('⚠️ 連線失敗，請確認網路後再試');
}
}
</script>
</body>
</html>
