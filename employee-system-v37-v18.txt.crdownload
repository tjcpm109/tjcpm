<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#000000">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="TJCPM">
<link rel="apple-touch-icon" href="https://tjcpm109.github.io/tjcpm/APP%20logo.png">
<link rel="icon" type="image/png" href="https://tjcpm109.github.io/tjcpm/APP%20logo.png">
<title>TJCPM 員工系統</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  /* ── 頂部黑金 Header ── */
  --bg-header: #000000;

  /* ── 頁面底：經典 V32 淡雅淺綠色 ── */
  --bg-page: #eaf5f0;         /* 經典 V32 淡雅淺綠色 */
  --bg-page-alt: #cbd5e1;     /* 暖灰色 */

  /* ── 卡片：V26 經典純白卡片 ── */
  --card-bg: #ffffff;         /* 純白色卡片 */
  --card-bg-soft: #f8fafc;    /* 輔助亮灰底 */
  --card-bg-hover: #f1f5f9;   /* 懸停底色 */
  --card-border: #475569;     /* 深板岩灰卡片與按鈕外框線，高對比立體感 */

  /* ── 藍色系（強調色） ── */
  --blue-main: #1a6fc4;       /* 經典企業深藍 */
  --blue-light: #2563eb;      /* 亮藍 */
  --blue-pale: #eff6ff;       /* 淺藍背景 */
  --blue-border: #3b82f6;     /* 藍色邊框 */
  --blue-text-on-pale: #1a6fc4; /* 淺藍背景上的深藍文字 */

  /* ── 綠色系（強調色） ── */
  --green-main: #059669;      /* 翠綠色 */
  --green-light: #10b981;     /* 亮綠色 */
  --green-pale: #ecfdf5;      /* 淺綠背景 */
  --green-border: #10b981;

  --accent-red: #ef4444;
  --accent-red-pale: #fef2f2;
  --accent-orange: #f59e0b;
  --accent-orange-pale: #fffbeb;
  --accent-purple: #7c3aed;
  --accent-purple-pale: #f5f3ff;

  /* ── 文字（卡片內，淺底用深字，即 V26 樣式） ── */
  --text-primary: #0f172a;    /* 絕對深炭黑文字（用於卡片內） */
  --text-secondary: #334155;  /* 輔助深灰文字 */
  --text-muted: #64748b;      /* 弱化灰色文字 */

  /* ── 頁面底色上的文字 ── */
  --page-text-primary: #0f172a;
  --page-text-secondary: #334155;
  --border: #475569;
  --border-bright: #334155;
  --shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
  --shadow-md: 0 8px 24px rgba(15, 23, 42, 0.15);
  --radius: 10px;
  --radius-lg: 16px;

  /* ── V26 大小字級 ── */
  --fs-body: 16px;
  --fs-label: 14px;
  --fs-btn: 16px;
}

body {
background:var(--bg-page);
color:var(--page-text-primary);
font-family:-apple-system,'PingFang TC','Microsoft JhengHei',sans-serif;
min-height:100vh;
font-size:var(--fs-body);
}

/* ── Login ── */
#loginScreen {
min-height:100vh;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
padding:24px;
background:linear-gradient(160deg, #d0ede0 0%, #e8f5f0 50%, #ddeaf8 100%);
}
.login-logo { margin-bottom:22px; width:100%; max-width:440px; }
.login-logo img { width:100%; max-width:440px; display:block; }
.login-logo .logo-fallback {
display:none;
background:var(--blue-main);
color:#fff;
font-size:42px;
font-weight:700;
padding:28px 48px;
border-radius:20px;
letter-spacing:4px;
}
.login-title { font-size:28px; font-weight:700; color:#1a6fc4; margin-bottom:4px; }
.login-sub { font-size:16px; color:var(--page-text-secondary); margin-bottom:32px; }

/* ── 登入框：淺色、放大、凸顯 ── */
.login-box {
background:#ffffff;
border:2px solid var(--blue-border);
border-radius:20px;
padding:40px 32px;
width:100%;
max-width:440px;
box-shadow:0 20px 50px rgba(26,111,196,0.22), 0 6px 18px rgba(17,24,39,0.10);
}
#loginScreen .input-field,
#loginScreen .select-field {
background:#f4f9f7;
border:1.5px solid #c8e2d8;
color:var(--page-text-primary);
}
#loginScreen .input-field::placeholder { color:#94a8a0; }
#loginScreen .input-field:focus,
#loginScreen .select-field:focus {
border-color:#1a6fc4;
box-shadow:0 0 0 3px rgba(26,111,196,0.15);
background:#ffffff;
}
#loginScreen .input-label { color:#3a5a4a; }
.login-err {
background:#fef2f2;
border:1px solid #fecaca;
border-radius:var(--radius);
padding:11px 14px;
font-size:var(--fs-body);
color:#dc2626;
margin-bottom:16px;
display:none;
}

/* ── Header ── */
.header {
  background: var(--bg-header);
  border-bottom: 2px solid var(--green-border);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: center; /* Centered Logo */
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--shadow);
}
.header-left {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
}
.header-left img {
  height: 52px !important; /* Increased height to 52px for 置中加大 */
  display: block;
  margin: 0 auto;
}
.header-right {
  display: flex;
  align-items: center;
  gap: 12px;
  position: absolute;
  right: 20px;
}
.header-left { display:flex; align-items:center; gap:10px; }
.header-left img { height:52px; transition: height 0.2s; } /* 置中加大 1.5 倍 */
.header-right { display:flex; align-items:center; gap:10px; }
.header-clock { font-size:var(--fs-label); color:var(--blue-light); font-variant-numeric:tabular-nums; font-weight:700; }
.header-user { font-size:var(--fs-label); color:var(--text-secondary); font-weight:500; }
.logout-btn {
font-size:var(--fs-label);
color:var(--accent-red);
cursor:pointer;
background:none;
border:1px solid #5c2a2e;
font-family:inherit;
padding:6px 12px;
border-radius:6px;
transition:background 0.15s;
}
.logout-btn:hover { background:var(--accent-red-pale); }
.notif-bell { font-size:21px; cursor:pointer; position:relative; }
.notif-badge {
position:absolute;
top:-4px;
right:-4px;
background:var(--accent-red);
color:#fff;
font-size:11px;
font-weight:900;
width:17px;
height:17px;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
pointer-events:none;
}

/* ── Nav ── */
    .nav {
      background: var(--bg-header) !important;
      border-bottom: 1.5px solid var(--card-border) !important;
      display: flex !important;
      width: 100% !important;
      overflow-x: hidden !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    .nav::-webkit-scrollbar { display:none !important; }
    .nav-tab {
      flex: 1 !important;
      text-align: center !important;
      padding: 13px 4px !important;
      font-size: var(--fs-label) !important;
      color: #94a3b8 !important; /* Changed from var(--text-secondary) to #94a3b8 for pure black background contrast */
      cursor: pointer !important;
      white-space: nowrap !important;
      border-bottom: 3px solid transparent !important;
      border-radius: 0 !important;
      border: none !important;
      transition: all 0.2s !important;
      font-weight: 700 !important;
      user-select: none !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
    }
    .nav-tab:hover {
      color: var(--blue-light) !important;
      background: var(--card-bg-hover) !important;
    }
    .nav-tab.active {
      color: var(--blue-light) !important;
      border-bottom: 3px solid var(--blue-light) !important;
      background: transparent !important; /* Remove white background on pure black bar */
    }
    .nav-tab:hover {
      color: var(--blue-light) !important;
      background: rgba(255, 255, 255, 0.08) !important; /* Dark theme hover accent */
    }

    /* ── Pages ── */
.page { display:none; padding:20px; max-width:700px; margin:0 auto; }
.page.active { display:block; }

/* ── Clock card ── */
.clock-card {
background: var(--card-bg) !important;
border: 1.5px solid var(--card-border) !important;
border-radius:var(--radius-lg);
padding:28px 24px;
text-align:center;
margin-bottom:16px;
box-shadow:var(--shadow-md);
color: var(--text-primary) !important;
}
.clock-time { font-size:54px; font-weight:bold; font-variant-numeric:tabular-nums; letter-spacing:-1px; line-height:1; color: var(--text-primary) !important; }
.clock-date { font-size:var(--fs-label); margin-top:8px; color: var(--text-secondary) !important; }
.clock-user { font-size:var(--fs-label); margin-top:10px; font-weight:700; color: var(--text-primary) !important; }

/* ── Inputs ── */
.input-group { margin-bottom:16px; }
.input-label { font-size:var(--fs-label); color:var(--page-text-secondary); margin-bottom:7px; display:block; font-weight:600; }
.input-field {
width:100%;
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius);
padding:13px 14px;
color:var(--text-primary);
font-size:var(--fs-body);
font-family:inherit;
transition:border-color 0.2s,box-shadow 0.2s;
outline:none;
}
.input-field:focus { border-color:var(--blue-light); box-shadow:0 0 0 3px rgba(96,165,250,0.2); }
.input-field::placeholder { color:var(--text-muted); }
.select-field {
width:100%;
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius);
padding:13px 14px;
color:var(--text-primary);
font-size:var(--fs-body);
font-family:inherit;
outline:none;
appearance:none;
cursor:pointer;
transition:border-color 0.2s;
}
.select-field:focus { border-color:var(--blue-light); box-shadow:0 0 0 3px rgba(96,165,250,0.2); }

/* ── Info box ── */
.info-box {
display:flex;
align-items:flex-start;
gap:10px;
background:var(--blue-pale);
border:1px solid var(--blue-border);
border-radius:var(--radius);
padding:13px 14px;
margin-bottom:20px;
}
.info-box .info-icon { font-size:19px; flex-shrink:0; margin-top:1px; }
.info-box .info-text { font-size:var(--fs-body); color:var(--blue-text-on-pale); line-height:1.65; }
.info-box .info-text strong { color:var(--blue-main) !important; }

/* ── Action buttons ── */
.action-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px; }
.action-btn {
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius-lg);
padding:24px 16px;
cursor:pointer;
text-align:center;
transition:all 0.18s;
user-select:none;
box-shadow:var(--shadow);
}
.action-btn:hover { background:var(--card-bg-hover); transform:translateY(-2px); box-shadow:var(--shadow-md); }
.action-btn:active { transform:scale(0.97); }
.action-btn .btn-icon { font-size:32px; margin-bottom:10px; display:block; }
.action-btn .btn-label { font-size:18px; font-weight:700; }
.action-btn .btn-sub { font-size:var(--fs-label); color:var(--text-muted); margin-top:4px; }
.btn-checkin { border-top:4px solid var(--green-main); }
.btn-checkin .btn-label { color:var(--green-light); }
.btn-checkout { border-top:4px solid var(--accent-red); }
.btn-checkout .btn-label { color:var(--accent-red); }

/* ── 離線與防呆 ── */
.action-btn.disabled {
opacity:0.45;
cursor:not-allowed;
pointer-events:none;
filter:grayscale(0.4);
}
.action-btn.disabled:hover { transform:none; box-shadow:var(--shadow); }
.offline-banner {
background:var(--accent-orange-pale);
border:1px solid #6b4f12;
color:var(--accent-orange);
border-radius:var(--radius);
padding:12px 16px;
margin-bottom:16px;
font-size:var(--fs-body);
display:none;
align-items:center;
gap:10px;
}
.offline-banner.show { display:flex; }

/* ── GPS bar ── */
.gps-bar {
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius);
padding:12px 14px;
display:flex;
align-items:center;
gap:10px;
margin-bottom:10px;
font-size:var(--fs-body);
box-shadow:var(--shadow);
}
.gps-dot { width:9px; height:9px; border-radius:50%; background:var(--text-muted); flex-shrink:0; transition:background 0.3s; }
.gps-dot.active { background: var(--green-light); }
.gps-dot.error { background: var(--accent-red); }
.gps-text { color: var(--text-primary); }
.gps-coords { color: var(--text-secondary); margin-left: auto; font-family: monospace; }

/* ── Section Title ── */
.section-title {
font-size: 16px;
font-weight: bold;
color: var(--page-text-primary);
margin: 20px 0 10px 0;
display: flex;
align-items: center;
gap: 6px;
}

/* ── Record Items ── */
.record-list { display: flex; flex-direction: column; gap: 8px; }
.record-item {
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius);
padding:14px 16px;
display:flex;
flex-direction:column;
gap:8px;
box-shadow:var(--shadow);
}
.record-row { display:flex; align-items:center; gap:14px; }
.record-dot { width:11px; height:11px; border-radius:50%; flex-shrink:0; }
.dot-green { background:var(--green-main); }
.dot-red { background:var(--accent-red); }
.dot-orange { background:var(--accent-orange); }
.dot-purple { background:var(--accent-purple); }
.dot-blue { background:var(--blue-light); }
.record-info { flex:1; }
.record-type { font-size:var(--fs-body); font-weight:600; color:var(--text-primary); display: flex; align-items: center; gap: 6px; }
.record-meta { font-size:var(--fs-label); color:var(--text-secondary); margin-top:3px; }
.record-time { font-size:var(--fs-body); color:var(--text-secondary); font-variant-numeric:tabular-nums; font-weight:500; }
.empty-state { text-align:center; padding:40px 20px; color:var(--page-text-secondary); }
.empty-icon { font-size:38px; margin-bottom:12px; }
.empty-text { font-size:var(--fs-body); }


/* ── Table designs ── */
.quota-table, .attendance-table {
  width: 100%;
  border-collapse: collapse;
  margin: 10px 0;
  font-size: 14px;
}
.quota-table th, .quota-table td,
.attendance-table th, .attendance-table td {
  border: 1px solid var(--card-border) !important;
  padding: 8px 10px;
  text-align: center;
}
.quota-table th, .attendance-table th {
  background: var(--card-bg-soft) !important;
  color: var(--text-secondary) !important;
  font-weight: 700;
}
.quota-table tbody td, .attendance-table tbody td {
  color: var(--text-primary) !important;
}

/* ── 三欄日曆表格樣式 ── */
.calendar-table-container {
background: var(--card-bg);
border: 1px solid var(--card-border);
border-radius: var(--radius-lg);
padding: 16px;
margin-top: 10px;
overflow-x: auto;
box-shadow: var(--shadow);
}
.calendar-table {
width: 100%;
border-collapse: collapse;
font-size: 14px;
text-align: left;
color: var(--text-primary);
}
.calendar-table th, .calendar-table td {
padding: 12px 10px;
border-bottom: 1px solid var(--card-border);
}
.calendar-table th {
font-weight: 700;
color: var(--text-secondary);
text-transform: uppercase;
font-size: 13px;
letter-spacing: 0.5px;
}
.calendar-table tr:last-child td { border-bottom: none; }
.calendar-row-missed { cursor: pointer; }
.calendar-row-missed:hover { background: var(--card-bg-soft); }

/* ── Modals ── */
.modal-overlay {
display:none;
position:fixed;
inset:0;
background:rgba(8,12,20,0.6);
z-index:200;
align-items:flex-end;
justify-content:center;
}
.modal-overlay.open { display:flex; }
.modal {
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius-lg) var(--radius-lg) 0 0;
padding:24px 20px 36px;
width:100%;
max-width:700px;
animation:slideUp 0.25s ease;
box-shadow:0 -4px 28px rgba(0,0,0,0.4);
}
@keyframes slideUp { from{ transform:translateY(40px); opacity:0; } to{ transform:translateY(0); opacity:1; } }
.modal-title { font-size:18px; font-weight:700; color:var(--blue-light); margin-bottom:20px; display:flex; align-items:center; gap:10px; }
.modal-close { margin-left:auto; background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:22px; line-height:1; padding:0; }

/* ── Buttons ── */
.submit-btn {
width:100%;
padding:15px;
border-radius:var(--radius);
border:none;
font-size:var(--fs-btn);
font-weight:700;
font-family:inherit;
cursor:pointer;
margin-top:8px;
transition:opacity 0.2s,transform 0.15s,box-shadow 0.15s;
box-shadow:var(--shadow);
}
.submit-btn:hover { opacity:0.92; box-shadow:var(--shadow-md); }
.submit-btn:active { transform:scale(0.98); }
.submit-btn.blue { background:var(--blue-main); color:#fff; }
.submit-btn.green { background:var(--green-main); color:#06241a; }
.submit-btn.orange { background:var(--accent-orange); color:#2b1f02; }
.submit-btn.purple { background:var(--accent-purple); color:#1c1334; }

/* ── Toast ── */
.toast {
position:fixed;
bottom:24px;
left:50%;
transform:translateX(-50%) translateY(80px);
background:#1e293b !important; /* Changed to #1e293b for Scheme 1 contrast */
border:1.5px solid var(--card-border) !important;
color:#ffffff !important; /* Changed to white */
border-radius:50px;
padding:12px 22px;
font-size:var(--fs-label);
font-weight:700;
z-index:300;
transition:transform 0.3s ease;
white-space:nowrap;
box-shadow:var(--shadow-md);
}
.toast.show { transform:translateX(-50%) translateY(0); }

/* ── Badges ── */
.badge { display:inline-block; font-size:12px; font-weight:700; padding:3px 9px; border-radius:20px; letter-spacing:0.3px; }
.badge-green { background:var(--green-pale); color:var(--green-light); }
.badge-red { background:var(--accent-red-pale); color:var(--accent-red); }
.badge-orange { background:var(--accent-orange-pale); color:var(--accent-orange); }
.badge-purple { background:var(--accent-purple-pale); color:var(--accent-purple); }
.badge-blue { background:var(--blue-pale); color:var(--blue-light); }
.badge-gray { background:#1f2937; color:#9ca3af; }

/* ── Stats ── */
.stats-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; margin-bottom:20px; }
.stat-card {
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius);
padding:16px;
box-shadow:var(--shadow);
border-top:3px solid var(--blue-light);
}
.stat-label { font-size:13px; color:var(--text-secondary); margin-bottom:6px; text-transform:uppercase; letter-spacing:0.6px; font-weight:700; }
.stat-value { font-size:30px; font-weight:300; color:var(--blue-light); }
.stat-value span { font-size:var(--fs-label); color:var(--text-muted); margin-left:4px; }

/* ── Approve buttons ── */
.approve-row { display:flex; gap:8px; }
.approve-btn {
font-size:var(--fs-label);
padding:8px 16px;
border-radius:6px;
border:none;
cursor:pointer;
font-family:inherit;
font-weight:600;
transition:opacity 0.15s;
}
.approve-btn.ok { background:var(--green-pale); color:var(--green-light); border:1px solid var(--green-border); }
.approve-btn.ok:hover { background:var(--green-border); }
.approve-btn.reject { background:var(--accent-red-pale); color:var(--accent-red); border:1px solid #5c2a2e; }
.approve-btn.reject:hover { background:#5c2a2e; }

/* ── Notif ── */
.notif-panel {
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius);
padding:14px 16px;
margin-bottom:8px;
display:flex;
gap:12px;
align-items:flex-start;
box-shadow:var(--shadow);
}
.notif-icon { font-size:20px; flex-shrink:0; }
.notif-text { font-size:var(--fs-body); color:var(--text-primary); }
.notif-time { font-size:var(--fs-label); color:var(--text-muted); margin-top:3px; }

/* ── Push banner ── */
.push-banner {
background:var(--blue-pale);
border:1px solid var(--blue-border);
border-radius:var(--radius);
padding:12px 16px;
margin-bottom:16px;
display:flex;
align-items:center;
gap:12px;
font-size:var(--fs-body);
color:var(--blue-text-on-pale);
}
.push-banner button {
background:var(--blue-main);
color:#fff;
border:none;
border-radius:6px;
padding:8px 14px;
font-size:var(--fs-label);
cursor:pointer;
font-family:inherit;
white-space:nowrap;
font-weight:600;
}

/* ── Filter chips ── */
.filter-bar { display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; }
.filter-chip {
font-size:var(--fs-label);
padding:7px 15px;
border-radius:20px;
background:var(--card-bg);
border:1px solid var(--card-border);
color:var(--text-secondary);
cursor:pointer;
transition:all 0.15s;
font-weight:500;
}
.filter-chip.active { background:var(--blue-pale); border-color:var(--blue-light); color:var(--blue-light); font-weight:700; }

/* ── Spinner ── */
.spinner {
display:inline-block;
width:16px;
height:16px;
border:2px solid rgba(255,255,255,0.4);
border-top-color:#fff;
border-radius:50%;
animation:spin 0.7s linear infinite;
vertical-align:middle;
margin-right:6px;
}
@keyframes spin { to{ transform:rotate(360deg); } }

/* ── Approve comment ── */
.approve-comment-area {
margin-top:10px;
display:none;
flex-direction:column;
gap:8px;
}
.approve-comment-area.open { display:flex; }
.approve-comment-input {
width:100%;
background:var(--card-bg-soft);
border:1px solid var(--card-border);
border-radius:var(--radius);
padding:10px 12px;
color:var(--text-primary);
font-size:var(--fs-label);
font-family:inherit;
resize:vertical;
min-height:60px;
outline:none;
transition:border-color 0.2s;
}
.approve-comment-input:focus { border-color:var(--blue-light); }
.approve-comment-input::placeholder { color:var(--text-muted); }
.approve-confirm-row { display:flex; gap:8px; }

/* ── Profile page ── */
.profile-card {
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius-lg);
padding:24px 20px;
margin-bottom:16px;
box-shadow:var(--shadow);
}
.profile-avatar {
width:64px; height:64px;
border-radius:50%;
background:linear-gradient(135deg, var(--blue-main), var(--green-main));
display:flex; align-items:center; justify-content:center;
font-size:28px; font-weight:700; color:#fff;
margin:0 auto 14px;
}
.profile-name { font-size:22px; font-weight:700; color:var(--text-primary); text-align:center; margin-bottom:4px; }
.profile-empid { font-size:var(--fs-label); color:var(--text-muted); text-align:center; }
.profile-meta-row {
display:flex; align-items:center; gap:10px;
padding:12px 0; border-bottom:1px solid var(--card-border);
font-size:var(--fs-body);
}
.profile-meta-row:last-child { border-bottom:none; }
.profile-meta-icon { font-size:18px; width:26px; flex-shrink:0; }
.profile-meta-label { color:var(--text-secondary); width:70px; flex-shrink:0; }
.profile-meta-value { color:var(--text-primary); flex:1; font-weight:500; }
.pw-toggle-btn {
background:none; border:1px solid var(--blue-border);
color:var(--blue-light); border-radius:6px;
padding:5px 10px; font-size:12px; cursor:pointer; font-family:inherit;
transition:background 0.15s;
}
.pw-toggle-btn:hover { background:var(--blue-pale); }
.pw-change-area { display:none; margin-top:12px; }
.pw-change-area.open { display:block; }

/* ── Attendance summary stats ── */
.attend-stats { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; margin-bottom:16px; }
.attend-card {
background:var(--card-bg);
border:1px solid var(--card-border);
border-radius:var(--radius);
padding:14px 12px; text-align:center;
box-shadow:var(--shadow);
}
.attend-card.red { border-top:3px solid var(--accent-red); }
.attend-card.orange { border-top:3px solid var(--accent-orange); }
.attend-card.purple { border-top:3px solid var(--accent-purple); }
.attend-card.blue { border-top:3px solid var(--blue-light); }
.attend-val { font-size:28px; font-weight:300; color:var(--text-primary); margin-bottom:4px; }
.attend-val.red { color:var(--accent-red); }
.attend-val.orange { color:var(--accent-orange); }
.attend-val.purple { color:var(--accent-purple); }
.attend-val.blue { color:var(--blue-light); }
.attend-lbl { font-size:12px; color:var(--text-secondary); font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }

/* 自適應防撞與大螢幕排版 */
@media(max-width:500px) {
.header-right .header-user, .header-right .header-clock { display: none !important; } /* 窄螢幕防撞 */
}
@media(min-width:600px) {
.page{ padding:28px 24px; }
.clock-time{ font-size:64px; }
}

/* 🏷️ 我的紀錄：假別與審核狀態標籤特別提權放大 */
.record-type .badge {
  font-size: 14px !important;
  padding: 4px 10px !important;
  border-radius: 6px !important;
  letter-spacing: 0.5px !important;
}


.subtab-chip {
font-size:var(--fs-label);
padding:7px 15px;
border-radius:20px;
background:var(--card-bg);
border:1px solid var(--card-border);
color:var(--text-secondary);
cursor:pointer;
transition:all 0.15s;
font-weight:500;
margin: 0 4px;
display: inline-block;
}
.subtab-chip.active { background:var(--blue-pale); border-color:var(--blue-light); color:var(--blue-light); font-weight:700; }

</style>
</head>
<body>
<!-- Login -->
<div id="loginScreen">
<div class="login-logo">
<img src="https://tjcpm109.github.io/tjcpm/logo.png" onerror="this.style.display='none';document.getElementById('logoTextLogin').style.display='block'" />
<div id="logoTextLogin" class="logo-fallback">TJCPM</div>
</div>
<div class="login-title">TJCPM</div>
<div class="login-sub">員工管理系統</div>
<div class="login-box">
<div class="login-err" id="loginErr"></div>
<div class="input-group">
<label class="input-label">員工編號</label>
<input class="input-field" id="loginId" placeholder="例：111、114" onkeydown="if(event.key==='Enter')document.getElementById('loginPw').focus()" />
</div>
<div class="input-group">
<label class="input-label">密碼</label>
<input class="input-field" type="password" id="loginPw" placeholder="請輸入密碼" onkeydown="if(event.key==='Enter')doLogin()" />
</div>
<button class="submit-btn blue" id="loginBtn" onclick="doLogin()">登入</button>
</div>
</div>

<!-- Main App -->
<div id="mainApp" style="display:none">
<div class="header">
<div class="header-left">
<img src="https://tjcpm109.github.io/tjcpm/logo.png" onerror="this.style.display='none';document.getElementById('logoTextHeader').style.display='inline-block'" />
<span id="logoTextHeader" style="display:none;background:var(--blue-main);color:#fff;font-size:15px;font-weight:700;padding:7px 14px;border-radius:8px;letter-spacing:1px;">TJCPM</span>
</div>
<div class="header-right">
<div class="notif-bell" id="notifBell">
🔔<span class="notif-badge" id="notifCount" style="display:none">!</span>
</div>
<span class="header-user" id="headerUser"></span>
<span class="header-clock" id="headerClock">--:--:--</span>
<button class="logout-btn" onclick="doLogout()">登出</button>
</div>
</div>
<div class="nav" id="mainNav">
<div class="nav-tab" id="adminTab" data-tab="admin" style="display:none" onclick="switchTab('admin')">👨💼 主管</div>
<div class="nav-tab active" data-tab="home" onclick="switchTab('home')">🏠 打卡</div>
<div class="nav-tab" data-tab="leave" onclick="switchTab('leave')">📅 請假</div>
<div class="nav-tab" data-tab="overtime" onclick="switchTab('overtime')">⏰ 加班</div>
<div class="nav-tab" data-tab="supp" onclick="switchTab('supp')">🔄 補打卡</div>
<div class="nav-tab" data-tab="records" onclick="switchTab('records')">📋 我的紀錄</div>
<div class="nav-tab" data-tab="profile" onclick="switchTab('profile')">👤 個人資料</div>
</div>

<!-- 打卡 -->
<div class="page active" id="page-home">
<div class="clock-card">
<div class="clock-time" id="mainClock">00:00:00</div>
<div class="clock-date" id="mainDate"></div>
<div class="clock-user" id="clockUser"></div>
</div>


<div class="gps-bar">
<div class="gps-dot" id="gpsDot"></div>
<span class="gps-text" id="gpsText">取得位置中…</span>
<span class="gps-coords" id="gpsCoords"></span>
</div>
<!-- ✍️ 全新簽到退詳細外勤異地說明輸入框 -->
<div class="input-group" style="margin-top: 14px; margin-bottom: 14px;">
  <label class="input-label" style="font-weight: 800;">📝 簽到退詳細說明（若非在雙和簽到退請說明）</label>
  <textarea class="input-field" id="punchRemark" rows="3"
            placeholder="若非在雙和簽到退請說明，例：人才課程至重慶上班、人才課程文大下班...等詳細說明"
            style="height: 100px; padding: 12px 14px; font-size: var(--fs-label); border: 2.5px solid var(--blue-main) !important; border-radius: var(--radius); resize: none; background: #ffffff; color: var(--text-primary); font-weight: 500; width: 100%; outline: none; transition: border-color 0.2s, box-shadow 0.2s;"></textarea>
</div>
<div class="offline-banner" id="offlineBanner">
⚠️ 目前無法連線，暫時無法打卡，請確認網路後再試
</div>
<div style="text-align:right;font-size:14px;margin-bottom:12px;min-height:18px;">
<span id="syncStatus" style="transition:color 0.3s;"></span>
</div>
<div class="action-grid">
<div class="action-btn btn-checkin" id="btnCheckin" onclick="handleAction('上班')">
<span class="btn-icon">✅</span>
<div class="btn-label">上班</div>
<div class="btn-sub" id="checkinSub">打卡上班</div>
</div>
<div class="action-btn btn-checkout" id="btnCheckout" onclick="handleAction('下班')">
<span class="btn-icon">🏁</span>
<div class="btn-label">下班</div>
<div class="btn-sub" id="checkoutSub">打卡下班</div>
</div>
</div>
</div>

<!-- 我的紀錄 -->
  <!-- 我的紀錄 -->
  <div class="page" id="page-records">
    <div class="filter-bar" style="justify-content: center; margin-bottom: 20px;">
      <div class="subtab-chip active" id="subtab-month" onclick="switchRecordSubTab('month')">本月考勤</div>
      <div class="subtab-chip" id="subtab-year" onclick="switchRecordSubTab('year')">年度累計</div>
      <div class="subtab-chip" id="subtab-detail" onclick="switchRecordSubTab('detail')">打卡明細</div>
    </div>
    
    <!-- 本月考勤頁籤內容 (行列交換水平橫表) -->
    <div id="record-month-content" style="display:block;">
      <p class="section-title">📊 本月累計考勤彙整 (橫表)</p>
      <div class="profile-card" style="padding:12px; overflow-x:auto;">
        <table class="attendance-table" id="monthSummaryTable" style="width: 100%; border-collapse: collapse; text-align: center;">
          <thead>
            <tr style="border-bottom: 1.5px solid var(--card-border); color: var(--text-secondary);">
              <th style="padding: 8px;">加班時數</th>
              <th style="padding: 8px;">漏打卡次數</th>
              <th style="padding: 8px;">補打卡次數</th>
              <th style="padding: 8px;">遲到次數</th>
              <th style="padding: 8px;">早退次數</th>
              <th style="padding: 8px;">請假時數</th>
            </tr>
          </thead>
          <tbody>
            <tr style="color: var(--text-primary); font-weight: bold;">
              <td id="m-ot" style="padding: 8px;">0.0 h</td>
              <td id="m-miss" style="padding: 8px; color: var(--accent-red);">0 次</td>
              <td id="m-supp" style="padding: 8px;">0 次</td>
              <td id="m-late" style="padding: 8px;">0 次</td>
              <td id="m-early" style="padding: 8px;">0 次</td>
              <td id="m-leave" style="padding: 8px;">0.0 h</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- 年度累計頁籤內容 -->
    <div id="record-year-content" style="display:none;">
      <p class="section-title">📅 個人年度出勤累計總表</p>
      <div class="profile-card" style="padding:12px; overflow-x:auto;">
        <table class="attendance-table" style="width: 100%; border-collapse: collapse; text-align: center;">
          <thead>
            <tr style="border-bottom: 1.5px solid var(--card-border); color: var(--text-secondary);">
              <th style="padding: 8px;">⏰ 累計加班時數</th>
              <th style="padding: 8px;">🔄 累計漏打卡次數</th>
              <th style="padding: 8px;">⚠️ 累計遲到/早退次數</th>
            </tr>
          </thead>
          <tbody>
            <tr style="color: var(--text-primary); font-weight: bold;">
              <td id="y-ot" style="padding: 8px; color: var(--blue-main);">0.0 h</td>
              <td id="y-miss" style="padding: 8px; color: var(--accent-red);">0 次</td>
              <td id="y-lateearly" style="padding: 8px; color: var(--accent-orange);">0 次</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- 打卡明細與假單篩選紀錄 -->
    <div id="record-detail-content" style="display:none;">
      <p class="section-title">📅 本月每日出勤與申請單明細</p>
      <div class="filter-bar" style="margin-bottom: 16px;">
        <div class="filter-chip active" onclick="filterRecords('打卡',this)">📅 打卡日曆</div>
        <div class="filter-chip" onclick="filterRecords('請假',this)">🌴 請假</div>
        <div class="filter-chip" onclick="filterRecords('加班',this)">⏰ 加班</div>
        <div class="filter-chip" onclick="filterRecords('補打卡',this)">🔄 補打卡</div>
      </div>
      <div class="record-list" id="allRecordsList"></div>
    </div>
  </div>
</div>

<!-- 請假 -->
<div class="page" id="page-leave">
<div class="info-box">
<div class="info-icon">📅</div>
<div class="info-text">
<strong>請假說明：</strong>請假以<strong>小時</strong>為單位，請填寫開始與結束時間。<br>
半天假 = 4 小時；全天假 = 8 小時。
</div>
</div>
<p class="section-title">請假申請</p>
<div class="input-group">
<label class="input-label">假別</label>
<select class="select-field" id="leaveType">
<option>特休</option>
<option>補休</option>
<option>事假</option>
<option>病假</option>
<option>公假</option>
<option>婚假</option>
<option>喪假</option>
</select>
</div>
<div class="input-group">
<label class="input-label">開始日期</label>
<input type="date" class="input-field" id="leaveStart" />
</div>
<div class="input-group">
<label class="input-label">開始時間</label>
<select class="select-field" id="leaveStartTime"></select>
</div>
<div class="input-group">
<label class="input-label">結束日期</label>
<input type="date" class="input-field" id="leaveEnd" />
</div>
<div class="input-group">
<label class="input-label">結束時間</label>
<select class="select-field" id="leaveEndTime"></select>
</div>
<div class="input-group">
<label class="input-label">原因（選填）</label>
<input class="input-field" id="leaveReason" placeholder="請假原因" />
</div>
<button class="submit-btn orange" onclick="submitLeave()">送出請假申請</button>
</div>

<!-- 加班 -->
<div class="page" id="page-overtime">
<div class="info-box">
<div class="info-icon">⏰</div>
<div class="info-text">
<strong>加班說明：</strong>滿<strong>1 小時</strong>後起算，以<strong>0.5 小時</strong>為單位遞增。<br>
例：1h、1.5h、2h、2.5h…
</div>
</div>
<p class="section-title">加班申請</p>
<div class="input-group">
<label class="input-label">加班日期</label>
<input type="date" class="input-field" id="otDate" />
</div>
<div class="input-group">
<label class="input-label">開始時間</label>
<select class="select-field" id="otStart"></select>
</div>
<div class="input-group">
<label class="input-label">結束時間</label>
<select class="select-field" id="otEnd"></select>
</div>
<div class="input-group">
<label class="input-label">加班原因</label>
<input class="input-field" id="otReason" placeholder="加班原因" />
</div>
<button class="submit-btn purple" onclick="submitOvertime()">送出加班申請</button>
</div>

<!-- 補打卡 -->
<div class="page" id="page-supp">
<div class="info-box">
<div class="info-icon">🔄</div>
<div class="info-text">
<strong>補打卡說明：</strong>若因離開辦公室忘記打卡，請在此填寫補打卡申請，送出後由主管審核確認。
</div>
</div>
<p class="section-title">補打卡申請</p>
<div class="input-group">
<label class="input-label">上班或下班</label>
<select class="select-field" id="suppType">
<option>上班</option>
<option>下班</option>
</select>
</div>
<div class="input-group">
<label class="input-label">日期</label>
<input type="date" class="input-field" id="suppDate" />
</div>
<div class="input-group">
<label class="input-label">時間</label>
<select class="select-field" id="suppTime"></select>
</div>
<div class="input-group">
<label class="input-label">未打卡原因</label>
<input class="input-field" id="suppReason" placeholder="請說明未打卡原因" />
</div>
<button class="submit-btn green" onclick="submitSupp()">送出補打卡申請</button>
</div>

<!-- 個人資料 -->
<div class="page" id="page-profile">
<!-- V26 經典大頭貼排版配置與內容 -->
<!-- 照片那區已依討論移除 -->
<p class="section-title">基本資料</p>
<div class="profile-card">
<div class="profile-meta-row">
<div class="profile-meta-icon">👤</div>
<div class="profile-meta-label">姓名</div>
<div class="profile-meta-value" id="profileNameVal">—</div>
</div>
<div class="profile-meta-row">
<div class="profile-meta-icon">📅</div>
<div class="profile-meta-label">到職日</div>
<div class="profile-meta-value" id="profileJoinDate">—</div>
</div>
<div class="profile-meta-row">
<div class="profile-meta-icon">🏷️</div>
<div class="profile-meta-label">員編</div>
<div class="profile-meta-value" id="profileEmpIdVal">—</div>
</div>
<div class="profile-meta-row">
<div class="profile-meta-icon">💼</div>
<div class="profile-meta-label">在職類型</div>
<div class="profile-meta-value" id="profileEmpType">—</div>
</div>
<div class="profile-meta-row">
<div class="profile-meta-icon">🔑</div>
<div class="profile-meta-label">密碼</div>
<div class="profile-meta-value" style="display:flex;align-items:center;gap:8px;">
<span>••••••</span>
<button class="pw-toggle-btn" onclick="togglePwChange()">修改密碼</button>
</div>
</div>
<div class="pw-change-area" id="pwChangeArea">
<div class="input-group" style="margin-bottom:10px;">
<label class="input-label">舊密碼</label>
<input type="password" class="input-field" id="pwOld" placeholder="請輸入舊密碼" />
</div>
<div class="input-group" style="margin-bottom:10px;">
<label class="input-label">新密碼</label>
<input type="password" class="input-field" id="pwNew" placeholder="請輸入新密碼" />
</div>
<div class="input-group" style="margin-bottom:10px;">
<label class="input-label">確認新密碼</label>
<input type="password" class="input-field" id="pwConfirm" placeholder="再次輸入新密碼" />
</div>
<button class="submit-btn blue" style="margin-top:0;" onclick="changePassword()">確認修改</button>
</div>
</div>



<!-- 雲端特休/補休即時賸餘卡片 -->
<p class="section-title">🌴 特休與補休賸餘額度</p>
<div class="profile-card" style="padding: 16px;">
<div style="display: flex; justify-content: space-between; margin-bottom: 12px; border-bottom: 1px solid var(--card-border); padding-bottom: 8px;">
<span style="font-weight: bold; color: var(--green-light);">🌴 特休賸餘</span>
<span id="profileAnnualLeave" style="font-size: 18px; font-weight: bold; color: var(--text-primary);">— 小時</span>
</div>
<div style="display: flex; justify-content: space-between; padding-bottom: 4px;">
<span style="font-weight: bold; color: var(--accent-purple);">⏰ 補休賸餘</span>
<span id="profileCompensatoryLeave" style="font-size: 18px; font-weight: bold; color: var(--text-primary);">— 小時</span>
</div>
</div>



<!-- ⚖️ 勞基法常用假別累計與給薪權益對照卡 -->
<p class="section-title" style="margin-top: 24px;">⚖️ 勞基法常用假別與給薪說明</p>
<div class="profile-card" style="padding: 16px; background: var(--card-bg); border: 1px solid var(--card-border); overflow-x: auto;">
<div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 12px; line-height: 1.5; padding: 10px; background: var(--card-bg-soft); border-radius: var(--radius); border-left: 4px solid var(--blue-main);">
<strong>💡 系統請假規範：</strong>請假一律以<strong>小時</strong>為單位，半天假登記為 4 小時，全天假登記為 8 小時。
</div>
<table style="width: 100%; border-collapse: collapse; font-size: 13px; text-align: left; color: var(--text-primary);">
<thead>
<tr style="border-bottom: 2px solid var(--card-border); color: var(--text-secondary);">
<th style="padding: 6px 4px;">假別</th>
<th style="padding: 6px 4px;">今年已請</th>
<th style="padding: 6px 4px;">勞基法規定與給薪說明</th>
</tr>
</thead>
<tbody>
<tr style="border-bottom: 1px solid var(--card-border);">
<td style="padding: 10px 4px; font-weight: bold; color: var(--green-light);">🌴 特休假</td>
<td id="accumAnnual" style="padding: 10px 4px; font-variant-numeric: tabular-nums;">0h</td>
<td style="padding: 10px 4px; color: var(--text-secondary);">工資照給 (全薪)。天數依到職年資遞增發給。</td>
</tr>
<tr style="border-bottom: 1px solid var(--card-border);">
<td style="padding: 10px 4px; font-weight: bold; color: var(--accent-purple);">⏰ 補休</td>
<td id="accumComp" style="padding: 10px 4px; font-variant-numeric: tabular-nums;">0h</td>
<td style="padding: 10px 4px; color: var(--text-secondary);">工資照給 (全薪)。加班時數 1:1 兌換，需限期休畢。</td>
</tr>
<tr style="border-bottom: 1px solid var(--card-border);">
<td style="padding: 10px 4px; font-weight: bold; color: var(--accent-orange);">🩹 普通病假</td>
<td id="accumSick" style="padding: 10px 4px; font-variant-numeric: tabular-nums;">0h</td>
<td style="padding: 10px 4px; color: var(--text-secondary);"><span style="color:var(--accent-orange); font-weight:bold;">折半發給 (半薪)</span>。未住院者一年上限 30 天。</td>
</tr>
<tr style="border-bottom: 1px solid var(--card-border);">
<td style="padding: 10px 4px; font-weight: bold; color: #f87171;">💼 事假</td>
<td id="accumPersonal" style="padding: 10px 4px; font-variant-numeric: tabular-nums;">0h</td>
<td style="padding: 10px 4px; color: var(--text-secondary);"><span style="color:#f87171; font-weight:bold;">期間不給薪 (無薪)</span>。一年累計最多請 14 天。</td>
</tr>
<tr>
<td style="padding: 10px 4px; font-weight: bold; color: var(--blue-light);">🏛️ 公/婚/喪假</td>
<td id="accumGov" style="padding: 10px 4px; font-variant-numeric: tabular-nums;">0h</td>
<td style="padding: 10px 4px; color: var(--text-secondary);">工資照給 (全薪)。依法定事由及憑證核給。</td>
</tr>
</tbody>
</table>
</div>
</div>

